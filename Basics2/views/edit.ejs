<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>Document</title>
</head>
<body>
    <div class="main w-full min-h-screen bg-zinc-900 text-white p-10">
        <a href="/" class="text-blue-400">Go Back To Home</a>
        <form action="/edit" method="post">
            <input class="block px-5 py-2 w-1/4 outline-none rounded-lg bg-zinc-500 mt-5" type="text" placeholder="Previous Name" name="prevname" value="<%= filename%>">
            <input class="block px-5 py-2 w-1/4 outline-none rounded-lg bg-zinc-700 mt-5" type="text" placeholder="New Name" name="newname">
            <input class="mt-5 px-5 py-2 bg-blue-400 rounded-md" type="submit" value="Update Name">
        </form>
    </div>
</body>
</html>