<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>Document</title>
</head>
<body>
    <div class="main w-full min-h-screen bg-zinc-900 text-white">
        <div class="form p-10">
            <form action="/create" method="post">
                <input class="block px-5 py-2 w-full outline-none rounded-lg bg-zinc-700" type="text" placeholder="Enter the title of your task" name="title">
                <textarea class="block px-5 mt-5 py-2 w-full  outline-none  rounded-lg resize-none bg-zinc-700" placeholder="Enter the Details of the task" name="details"></textarea>
                <input class="mt-5 px-5 py-2 bg-gray-500 rounded-md" type="submit" value="Create Task">
            </form>
        </div>   

        <div class="tasks flex flex-wrap gap-3 p-10">

            <% if(files.length > 0){ %>
                <% files.forEach(function(val) { %>
                    <div class="task w-72 px-3 py-4 rounded-md bg-zinc-700">
                        <h1 class="text-white text-2xl tracking-tighter"> <%= val %> </h1>
                        <div class="flex item-center w-full justify-between mt-3">
                            <a class="text-blue-400 inline-block" href="/file/<%= val %>">Read more...</a>
                            <a href="/edit/<%= val %>" class="text-zinc-900">Edit Filename</a>
                        </div>
                    </div>
                <% }) %>
                <% } else { %>
                    <h3>No Task Yet.</h3>
                <% } %>

        </div>
    </div>
</body>
</html>