<!DOCTYPE html>
<html lang="en">
<head>
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
   <div class="w-full h-full p-10 bg-zinc-800 text-white">
        
        <div class="nav mb-5 text-xl tracking-tighter font-semibold">
            <a href="/read" class="text-blue-400">Read Users</a>
        </div>

        <form action="/update/<%= user._id %>" method="post">
            <h1 class="text-3xl tracking-tighter mb-5">Update User</h1>

            <input type="text" class="px-5 py-2 border-2 border-zinc-600 rounded-lg outline-none bg-transparent" name="name" value="<%= user.name %>"  placeholder="Enter Your Name : ">
            <input type="text" class="px-5 py-2 border-2 border-zinc-600 rounded-lg outline-none bg-transparent" name="email" value="<%= user.email%>" placeholder="Enter Your Email : ">
            <input type="text" class="px-5 py-2 border-2 border-zinc-600 rounded-lg outline-none bg-transparent" name="img" value="<%= user.img %>" placeholder="Enter img URL : ">

            <input type="submit" class="px-5 py-2 border-2 bg-yellow-500 rounded-lg ml-5" value="Update User">
        </form>
   </div>
</body>
</html>