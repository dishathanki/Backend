<!DOCTYPE html>
<html lang="en">
<head>
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <div class="w-full flex justify-end mr-5">
             <a href="/logout" class="tracking-tighter font-semibold text-red-500 mb-3 inline-block">Logout</a>
        </div>
        <h5 class="mb-5">Edit your Post:</h5>
        <form action="/update/<%= post._id %>" method="post">
            <textarea name="content" placeholder="What's in your mind ?" class="block p-3 rounded-lg w-1/3 resize-none bg-transparent border-2 border-zinc-700">
                <%= post.content %>
            </textarea>
            <input type="submit" class="px-3 w-40 py-2 bg-yellow-600 block rounded-lg mt-3" value="Update Post">
        </form>
    </div>
</body>
</html>