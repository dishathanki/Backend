<!DOCTYPE html>
<html lang="en">
<head>
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <form action="/register" method="post">
            <div class="flex">
                <h2 class="tracking-tighter flex font-semibold text-2xl text-blue-500">Create An Account:</h2>
                <a href="/login" class="tracking-tighter ml-8 font-semibold text-xl text-blue-500">Already have an account?</a>
            </div>
            <input type="text" class="px-3 py-2 mt-4 outline-none bg-transparent border-2 rounded border-zinc-700" placeholder="Enter Your Name : " name="name">
            <input type="text" class="px-3 py-2 ml-4 outline-none bg-transparent rounded border-2 border-zinc-700" placeholder="Enter Username : " name="username">
            <input type="number" class="px-3 py-2 ml-4 outline-none bg-transparent rounded border-2 border-zinc-700" placeholder="Enter Your Age : " name="age">
            <input type="email" class="px-3 py-2 ml-4 outline-none bg-transparent rounded border-2 border-zinc-700" placeholder="Enter Your Email : " name="email">
            <input type="password" class="px-3 py-2 ml-4 outline-none bg-transparent rounded border-2 border-zinc-700" placeholder="Enter Your Password : " name="password">

            <input type="submit" class="ml-4 border-2 px-3 py-2 bg-blue-500 rounded" value="Create Account">
        </form>
    </div>
</body>
</html>