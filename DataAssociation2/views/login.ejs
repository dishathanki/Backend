<!DOCTYPE html>
<html lang="en">
<head>
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <form action="/login" method="post">
            <h2 class="tracking-tighter font-semibold text-2xl text-blue-500">Login Into Your Account</h2>
            <input type="email" class="px-3 py-2 mt-3 ml-4 outline-none bg-transparent rounded border-2 border-zinc-700" placeholder="Enter Your Email : " name="email">
            <input type="password" class="px-3 py-2 ml-4 outline-none bg-transparent rounded border-2 border-zinc-700" placeholder="Enter Your Password : " name="password">

            <input type="submit" class="ml-4 border-2 px-3 py-2 bg-blue-500 rounded" value="Login Into Your Account">
        </form>
    </div>
</body>
</html>