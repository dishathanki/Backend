<!DOCTYPE html>
<html lang="en">
<head>
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">

        <a href="/logout" class="tracking-tighter font-semibold text-red-500 mb-3 inline-block">Logout</a>
        
        <div class="flex items-start gap-3">
            <div class="w-15 h-15 bg-red-500 rounded-md overflow-hidden">
                <img class="w-full h-full object-cover" src="/images/upload/<%= user.profilepic %>" alt="">
            </div>
             <h3 class="text-xl"><span class="tracking-tighter font-semibold text-2xl text-blue-500">Hello</span> , <%=user.name %>👋</h3>
        </div>
       
    
        <h5 class="mb-5 mt-3">You can create a new Post</h5>

        <form action="/post" method="post">
            <textarea name="content" placeholder="What's in your mind ?" class="block p-3 rounded-lg w-1/3 resize-none bg-transparent border-2 border-zinc-700"></textarea>
            <input type="submit" class="px-3 w-40 py-2 bg-blue-500 block rounded-lg mt-3" value="Create a new Post">
        </form>

        <div class="posts mt-20">
            <h3 class="text-zinc-400 text-xl">Your Posts:</h3>

            <div class="postcontainer mt-5">

                <% user.posts.reverse().forEach(function(post){ %>
                    <div class="post w-1/3 p-4  mb-4 rounded-md bg-zinc-700 border-[1px] border-zinc-700">
                        <h4 class="text-blue-500 font-semibold mb-2"> <%= user.username %> </h4>
                        <p class="text-sm tracking-tight"> <%= post.content %> </p>
                        <small class="mt-2 inline-block"> <%= post.likes.length %> </small>
                        <div class="btns flex gap-4 mt-1">
                            <a class="text-pink-500" href="/like/<%= post._id %>">
                                <%= post.likes.indexOf(user._id) === -1 ? "Like♥️" : "Unlike" %>
                            </a>
                            <a class="text-yellow-400" href="/edit/<%= post._id %>">Edit</a>
                        </div>
                    </div>
                <% }) %>

            </div>

        </div>
    </div>
</body>
</html>