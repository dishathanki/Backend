<!DOCTYPE html>
<html lang="en">
<head>
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <form action="/upload" method="post" autocomplete="off" enctype="multipart/form-data">
            <div class="flex justify-spacebetween mr-5">
                <h2 class="tracking-tighter flex font-semibold text-2xl text-blue-500">Upload Profile Picture</h2>
                <a href="/logout" class="tracking-tighter ml-15 font-semibold text-red-500 mb-3 inline-block">Logout</a>
            </div>
            <input type="file" name="image">

            <input type="submit" class="ml-4 border-2 px-3 py-2 bg-blue-500 rounded" value="Upload File">
        </form>
    </div>
</body>
</html>